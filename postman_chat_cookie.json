{
  "info": {
    "_postman_id": "postman-chat-cookie",
    "name": "Chat API (cookie auth)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get CSRF Cookie",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Accept", "value": "application/json" }
        ],
        "url": "{{base_url}}/sanctum/csrf-cookie"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 204 || pm.response.code === 200) {",
              "  var xsrf = pm.cookies.get('XSRF-TOKEN') || '';",
              "  if (xsrf) { pm.environment.set('XSRF-TOKEN', xsrf); }",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Login (cookie)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-XSRF-TOKEN", "value": "{{XSRF-TOKEN}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"test@example.com\",\"password\":\"password\"}"
        },
        "url": "{{base_url}}/login"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": { "exec": ["var xsrf = pm.cookies.get('XSRF-TOKEN'); if (xsrf) { pm.environment.set('XSRF-TOKEN', xsrf); }"] }
        },
        {
          "listen": "test",
          "script": { "exec": ["var xsrf = pm.cookies.get('XSRF-TOKEN') || ''; if (xsrf) { pm.environment.set('XSRF-TOKEN', xsrf); }", "pm.test('Login status is 200 or 302', function(){ pm.expect(pm.response.code).to.be.oneOf([200,302]); });"] }
        }
      ]
    },
    {
      "name": "Get Messages (cookie)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Accept", "value": "application/json" },
          { "key": "X-XSRF-TOKEN", "value": "{{XSRF-TOKEN}}" }
        ],
        "url": {
          "raw": "{{base_url}}/api/chat/messages?chatroom_id={{chatroom_id}}",
          "host": [ "{{base_url}}" ],
          "path": [ "api", "chat", "messages" ],
          "query": [ { "key": "chatroom_id", "value": "{{chatroom_id}}" } ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": { "exec": ["var xsrf = pm.cookies.get('XSRF-TOKEN'); if (xsrf) { pm.environment.set('XSRF-TOKEN', xsrf); }"] }
        }
      ]
    },
    {
      "name": "Post Message (cookie)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-XSRF-TOKEN", "value": "{{XSRF-TOKEN}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"chatroom_id\":{{chatroom_id}},\"messages\":\"Hello from Postman (cookie)\",\"status\":1}"
        },
        "url": "{{base_url}}/api/chat/messages"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": { "exec": ["var xsrf = pm.cookies.get('XSRF-TOKEN'); if (xsrf) { pm.environment.set('XSRF-TOKEN', xsrf); }"] }
        }
      ]
    }
  ]
}
