{
  "info": {
    "name": "Jem8 Admin Products",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Login (save token from body)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"adminsecret\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/login", "host": ["{{baseUrl}}"], "path": ["api","login"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Save token from JSON response body into environment variable 'token'",
              "pm.test('Response has token', function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json).to.have.property('token');",
              "  pm.environment.set('token', json.token);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Add Product (multipart/form-data)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "product_name", "value": "Test Product", "type": "text" },
            { "key": "category_id", "value": "1", "type": "text" },
            { "key": "product_stocks", "value": "10", "type": "text" },
            { "key": "price", "value": "9.99", "type": "text" },
            { "key": "description", "value": "Created from Postman", "type": "text" },
            { "key": "isSale", "value": "1", "type": "text" },
            { "key": "images[]", "type": "file", "src": "" }
          ]
        },
        "url": { "raw": "{{baseUrl}}/api/admin/products", "host": ["{{baseUrl}}"], "path": ["api","admin","products"] }
      }
    },
    {
      "name": "Show All Admin Products",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/admin/products", "host": ["{{baseUrl}}"], "path": ["api","admin","products"] }
      }
    },
    {
      "name": "Show Single Product",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/admin/products/:id", "host": ["{{baseUrl}}"], "path": ["api","admin","products",":id"] }
      }
    },
    {
      "name": "Update Product (POST/PUT)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "formdata", "formdata": [
          { "key": "product_name", "value": "Updated name", "type": "text" },
          { "key": "price", "value": "12.50", "type": "text" },
          { "key": "images[]", "type": "file", "src": "" },
          { "key": "remove_images[]", "value": "1", "type": "text" }
        ] },
        "url": { "raw": "{{baseUrl}}/api/admin/products/:id", "host": ["{{baseUrl}}"], "path": ["api","admin","products",":id"] }
      }
    },
    {
      "name": "Delete Product",
      "request": {
        "method": "DELETE",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/admin/products/:id", "host": ["{{baseUrl}}"], "path": ["api","admin","products",":id"] }
      }
    },
    {
      "name": "Test Upload (single file)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "formdata", "formdata": [ { "key": "test_image", "type": "file", "src": "" } ] },
        "url": { "raw": "{{baseUrl}}/api/admin/products/test-upload", "host": ["{{baseUrl}}"], "path": ["api","admin","products","test-upload"] }
      }
    },
    {
      "name": "Storage Info",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/admin/products/storage-info", "host": ["{{baseUrl}}"], "path": ["api","admin","products","storage-info"] }
      }
    }
  ]
}
